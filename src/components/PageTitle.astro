---
import Default from '@astrojs/starlight/components/PageTitle.astro';

const { entry, lang } = Astro.locals.starlightRoute;
const editions = entry.data.editions as
	| Array<'edge' | 'cloud' | 'enterprise'>
	| undefined;

const LABELS: Record<string, string> = {
	edge: 'Edge',
	cloud: 'Cloud',
	enterprise: 'Enterprise',
};
const EDITION_ORDER: Array<'edge' | 'cloud' | 'enterprise'> = ['edge', 'cloud', 'enterprise'];

const AVAILABLE_IN: Record<string, string> = {
	en: 'Available in',
	'zh-CN': '适用版本',
	ja: '対応エディション',
	es: 'Disponible en',
};
const availableIn = AVAILABLE_IN[lang] ?? AVAILABLE_IN.en;
const orderedEditions = editions
	? EDITION_ORDER.filter((edition) => editions.includes(edition))
	: undefined;
---

<Default><slot /></Default>
{
	orderedEditions && orderedEditions.length > 0 && (
		<div class="t0-editions" aria-label={availableIn}>
			<span class="t0-editions-label">{availableIn}</span>
			{orderedEditions.map((e) => (
				<span class={`t0-edition t0-edition--${e}`}>{LABELS[e]}</span>
			))}
		</div>
	)
}
